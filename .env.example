BOT_TOKEN=your_bot_token_here
DATABASE_URL=postgresql://user:password@localhost:5432/shroom

# Свой постоянный канал (оставь пустым если не нужен)
OWN_CHANNEL_ID=@your_channel

# Твой Telegram ID — будет добавлен как первый администратор при старте
# Узнать можно у @userinfobot
FIRST_ADMIN_ID=123456789

USE_WEBHOOK=false
WEBHOOK_HOST=https://yourdomain.com
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8080

ADMIN_SECRET=changeme
ADMIN_PORT=8000
NEARBY_RADIUS_KM=50
